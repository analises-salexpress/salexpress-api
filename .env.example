# App
PORT=3000
NODE_ENV=development

# JWT (TROQUE esta chave antes de ir para produção)
JWT_SECRET=troque-esta-chave-secreta-por-algo-aleatorio-longo
JWT_EXPIRES_IN=8h

# Banco App - Supabase PostgreSQL
# Pegue essas URLs em: Supabase → Settings → Database → Connection string
# "Transaction" mode (porta 6543) - para o servidor web (Railway)
APP_DATABASE_URL=postgresql://postgres.xxxx:senha@aws-0-sa-east-1.pooler.supabase.com:6543/postgres?pgbouncer=true
# "Session" mode (porta 5432) - para migrations
APP_DATABASE_DIRECT_URL=postgresql://postgres.xxxx:senha@aws-0-sa-east-1.pooler.supabase.com:5432/postgres

# Supabase (para upload de arquivos)
SUPABASE_URL=https://seuproject.supabase.co
SUPABASE_SERVICE_ROLE_KEY=sua-service-role-key

# Banco BI - banco existente da empresa (somente leitura)
BI_DB_HOST=localhost
BI_DB_PORT=3306
BI_DB_USER=usuario_readonly
BI_DB_PASSWORD=senha
BI_DB_NAME=nome_do_banco_bi

# CORS - domínio do Lovable (ex: https://meuapp.lovable.app) ou * para desenvolvimento
CORS_ORIGIN=*

# Upload de arquivos
UPLOAD_DIR=./uploads
MAX_FILE_SIZE_MB=10
