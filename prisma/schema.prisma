generator client {
  provider      = "prisma-client-js"
  binaryTargets = ["native", "linux-musl-openssl-3.0.x", "linux-musl"]
}

datasource db {
  provider  = "postgresql"
  url       = env("APP_DATABASE_URL")
  directUrl = env("APP_DATABASE_DIRECT_URL")
}

enum Role {
  VENDOR
  MANAGER
}

enum CardStatus {
  IDENTIFIED
  CONTACTED
  NEGOTIATING
  EXPANDED
  LOST
}

enum Priority {
  HIGH
  MEDIUM
  LOW
}

enum GoalStatus {
  ACTIVE
  ACHIEVED
  CANCELLED
}

model User {
  id           String   @id @default(cuid())
  name         String
  email        String   @unique
  passwordHash String
  role         Role     @default(VENDOR)
  active              Boolean  @default(true)
  mustChangePassword  Boolean  @default(false)
  createdAt           DateTime @default(now())
  updatedAt           DateTime @updatedAt

  assignedCards        KanbanCard[]          @relation("AssignedCards")
  createdCards         KanbanCard[]          @relation("CreatedCards")
  activities           KanbanActivity[]
  notes                KanbanNote[]
  sentMessages         Message[]             @relation("SentMessages")
  receivedMessages     Message[]             @relation("ReceivedMessages")
  uploadedFiles        File[]
  expansionGoals       ExpansionGoal[]
  refreshTokens        RefreshToken[]
  hypercareClients     HypercareClient[]
  hypercareTouchpoints HypercareTouchpoint[]
  hypercareMeetings    HypercareMeeting[]
}

model KanbanCard {
  id                      String     @id @default(cuid())
  clientId                String
  clientName              String
  status                  CardStatus @default(IDENTIFIED)
  priority                Priority   @default(MEDIUM)
  assignedToId            String?
  createdById             String
  manualExpansionPotential Float?    @map("manual_expansion_potential")
  expansionForecast        Float?    @map("expansion_forecast")
  currentCarrier           String?   @map("current_carrier")
  createdAt               DateTime   @default(now())
  updatedAt               DateTime   @updatedAt

  assignedTo      User?                @relation("AssignedCards", fields: [assignedToId], references: [id])
  createdBy       User                 @relation("CreatedCards", fields: [createdById], references: [id])
  activities      KanbanActivity[]
  notes           KanbanNote[]
  files           File[]
  goals           ExpansionGoal[]
  additionalCnpjs CardAdditionalCnpj[]

  @@index([clientId])
  @@index([assignedToId])
  @@index([status])
}

model CardAdditionalCnpj {
  id        String     @id @default(cuid())
  cardId    String
  cnpj      String
  name      String
  createdAt DateTime   @default(now())

  card KanbanCard @relation(fields: [cardId], references: [id], onDelete: Cascade)

  @@unique([cardId, cnpj])
  @@index([cardId])
  @@map("card_additional_cnpjs")
}

model KanbanNote {
  id        String     @id @default(cuid())
  cardId    String
  userId    String
  content   String     @db.Text
  createdAt DateTime   @default(now())

  card KanbanCard @relation(fields: [cardId], references: [id], onDelete: Cascade)
  user User       @relation(fields: [userId], references: [id])

  @@index([cardId])
}

model KanbanActivity {
  id        String   @id @default(cuid())
  cardId    String
  userId    String
  action    String
  oldStatus String?
  newStatus String?
  createdAt DateTime @default(now())

  card KanbanCard @relation(fields: [cardId], references: [id], onDelete: Cascade)
  user User       @relation(fields: [userId], references: [id])

  @@index([cardId])
}

model Message {
  id         String    @id @default(cuid())
  senderId   String
  receiverId String
  content    String    @db.Text
  readAt     DateTime?
  createdAt  DateTime  @default(now())

  sender   User @relation("SentMessages", fields: [senderId], references: [id])
  receiver User @relation("ReceivedMessages", fields: [receiverId], references: [id])

  @@index([senderId, receiverId])
  @@index([receiverId, readAt])
}

model File {
  id           String   @id @default(cuid())
  name         String
  path         String
  mimeType     String
  uploadedById String
  clientId     String?
  cardId       String?
  isEvidence   Boolean  @default(false) @map("is_evidence")
  createdAt    DateTime @default(now())

  uploadedBy User        @relation(fields: [uploadedById], references: [id])
  card       KanbanCard? @relation(fields: [cardId], references: [id])

  @@index([clientId])
  @@index([cardId])
}

model ExpansionGoal {
  id          String     @id @default(cuid())
  clientId    String
  vendorId    String
  cardId      String?
  startDate   DateTime
  baselineAvg Float
  targetValue Float?
  status      GoalStatus @default(ACTIVE)
  createdAt   DateTime   @default(now())
  updatedAt   DateTime   @updatedAt

  vendor    User                @relation(fields: [vendorId], references: [id])
  card      KanbanCard?         @relation(fields: [cardId], references: [id])
  weekNotes ExpansionWeekNote[]

  @@index([clientId])
  @@index([vendorId])
}

model ExpansionWeekNote {
  id          String   @id @default(cuid())
  goalId      String
  year        Int
  week        Int
  observation String?  @db.Text
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  goal ExpansionGoal @relation(fields: [goalId], references: [id], onDelete: Cascade)

  @@unique([goalId, year, week])
  @@index([goalId])
  @@map("expansion_week_notes")
}

model RefreshToken {
  id        String   @id @default(cuid())
  token     String   @unique
  userId    String
  expiresAt DateTime
  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

// ───── Cache dos dados do BI (sincronizado pelo agente de sync) ─────

model BiClient {
  cnpj        String   @id
  name        String
  groupedName String
  city        String?
  state       String?
  segment     String?
  curve       String?
  tipo        String?
  syncedAt    DateTime @default(now())

  @@map("bi_clients")
}

model BiClientMonthly {
  id              Int      @id @default(autoincrement())
  clientCnpj      String
  clientGrouped   String
  year            Int
  month           Int
  billing         Float    @default(0)
  deliveriesCount Int      @default(0)
  volumesCount    Int      @default(0)
  totalWeightKg   Float    @default(0)
  syncedAt        DateTime @default(now())

  @@unique([clientCnpj, year, month])
  @@index([clientCnpj])
  @@map("bi_client_monthly")
}

model BiClientWeekly {
  id              Int      @id @default(autoincrement())
  clientCnpj      String
  year            Int
  week            Int
  billing         Float    @default(0)
  deliveriesCount Int      @default(0)
  syncedAt        DateTime @default(now())

  @@unique([clientCnpj, year, week])
  @@index([clientCnpj])
  @@map("bi_client_weekly")
}

model BiClientRoute {
  id               Int      @id @default(autoincrement())
  clientCnpj       String   @map("client_cnpj")
  region           String
  firstSeen        DateTime @map("first_seen")
  lastSeen         DateTime @map("last_seen")
  tripCount        Int      @default(1) @map("trip_count")
  totalRevenue     Float    @default(0) @map("total_revenue")
  recentMonthlyAvg Float    @default(0) @map("recent_monthly_avg")
  syncedAt         DateTime @default(now()) @map("synced_at")

  @@unique([clientCnpj, region])
  @@index([clientCnpj])
  @@map("bi_client_routes")
}

model OpportunityExclusion {
  id         Int      @id @default(autoincrement())
  cnpj       String   @unique
  excludedBy String
  excludedAt DateTime @default(now())

  @@map("opportunity_exclusions")
}

model BiClientDaily {
  id              Int      @id @default(autoincrement())
  clientCnpj      String   @map("client_cnpj")
  date            DateTime @map("date") @db.Date
  billing         Float    @default(0)
  deliveriesCount Int      @default(0) @map("deliveries_count")
  syncedAt        DateTime @default(now()) @map("synced_at")

  @@unique([clientCnpj, date])
  @@index([clientCnpj])
  @@map("bi_client_daily")
}

model BiAllRoute {
  id           Int      @id @default(autoincrement())
  region       String   @unique
  avgRevenue   Float    @default(0) @map("avg_revenue")
  tripCount    Int      @default(0) @map("trip_count")
  totalRevenue Float    @default(0) @map("total_revenue")
  clientCount  Int      @default(0) @map("client_count")
  syncedAt     DateTime @default(now()) @map("synced_at")

  @@map("bi_all_routes")
}

// ───── HyperCare ─────────────────────────────────────────────────────────────

enum HypercareStatus {
  ACTIVE
  GRADUATED
  CANCELLED
}

enum TouchpointType {
  CALL
  EMAIL
  VISIT
  GGR_MEETING
  WHATSAPP
  OTHER
}

enum TouchpointOutcome {
  POSITIVE
  NEUTRAL
  NEGATIVE
}

enum ActionItemStatus {
  OPEN
  DONE
}

model HypercareClient {
  id           String          @id @default(cuid())
  cnpj         String          @unique
  clientName   String
  status       HypercareStatus @default(ACTIVE)
  enrolledAt   DateTime        @default(now())
  enrolledById String
  notes        String?         @db.Text
  createdAt    DateTime        @default(now())
  updatedAt    DateTime        @updatedAt

  enrolledBy      User                    @relation(fields: [enrolledById], references: [id])
  touchpoints     HypercareTouchpoint[]
  meetings        HypercareMeeting[]
  additionalCnpjs HypercareClientCnpj[]

  @@index([cnpj])
  @@index([status])
  @@map("hypercare_clients")
}

model HypercareClientCnpj {
  id        String   @id @default(cuid())
  clientId  String
  cnpj      String
  name      String
  createdAt DateTime @default(now())

  client HypercareClient @relation(fields: [clientId], references: [id], onDelete: Cascade)

  @@unique([clientId, cnpj])
  @@index([clientId])
  @@map("hypercare_client_cnpjs")
}

model HypercareTouchpoint {
  id         String            @id @default(cuid())
  clientId   String
  userId     String
  type       TouchpointType
  summary    String            @db.Text
  outcome    TouchpointOutcome
  occurredAt DateTime
  createdAt  DateTime          @default(now())

  client HypercareClient @relation(fields: [clientId], references: [id], onDelete: Cascade)
  user   User            @relation(fields: [userId], references: [id])

  @@index([clientId])
  @@map("hypercare_touchpoints")
}

model HypercareMeeting {
  id          String   @id @default(cuid())
  clientId    String
  userId      String
  meetingDate DateTime
  agenda      String?  @db.Text
  minutes     String?  @db.Text
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  client      HypercareClient       @relation(fields: [clientId], references: [id], onDelete: Cascade)
  user        User                  @relation(fields: [userId], references: [id])
  actionItems HypercareActionItem[]

  @@index([clientId])
  @@map("hypercare_meetings")
}

model HypercareActionItem {
  id          String           @id @default(cuid())
  meetingId   String
  description String           @db.Text
  responsible String
  dueDate     DateTime?
  status      ActionItemStatus @default(OPEN)
  createdAt   DateTime         @default(now())
  updatedAt   DateTime         @updatedAt

  meeting HypercareMeeting @relation(fields: [meetingId], references: [id], onDelete: Cascade)

  @@index([meetingId])
  @@map("hypercare_action_items")
}
